{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenClaw Skill Schema",
  "description": "Skill 元数据规范",
  "type": "object",
  "required": ["name", "version", "entrypoint"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Skill 唯一标识符",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "description": "语义化版本",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-z0-9]+)?$"
    },
    "description": {
      "type": "string",
      "description": "Skill 功能描述"
    },
    "entrypoint": {
      "type": "object",
      "required": ["script", "runtime"],
      "properties": {
        "script": {
          "type": "string",
          "description": "入口脚本路径"
        },
        "runtime": {
          "type": "string",
          "enum": ["python", "node", "bash", "binary"],
          "description": "运行时环境"
        },
        "method": {
          "type": "string",
          "description": "调用方法（函数名）",
          "default": "main"
        }
      }
    },
    "dependencies": {
      "type": "array",
      "description": "依赖的其他 Skill",
      "items": {
        "type": "object",
        "properties": {
          "skill": {"type": "string"},
          "version_range": {"type": "string"}
        }
      }
    },
    "permissions": {
      "type": "array",
      "description": "执行权限声明",
      "items": {
        "type": "string",
        "enum": ["network", "filesystem", "exec", "gpu", "microphone", "camera"]
      }
    },
    "capabilities": {
      "type": "array",
      "description": "提供的能力列表",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "description": {"type": "string"},
          "input_schema": {"type": "object"},
          "output_schema": {"type": "object"}
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "author": {"type": "string"},
        "license": {"type": "string"},
        "homepage": {"type": "string"},
        "repository": {"type": "string"},
        "tags": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "config": {
      "type": "object",
      "description": "Skill 默认配置"
    }
  }
}
