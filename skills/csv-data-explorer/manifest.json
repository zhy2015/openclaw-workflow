{
  "name": "csv-data-explorer",
  "description": "Explore, filter, summarize, and visualize CSV data directly in terminal with interactive queries.",
  "category": "data",
  "version": "1.0.0",
  "task_nodes": [
    "automation",
    "memory"
  ],
  "status": "experimental",
  "visibility": "public",
  "execution_type": "python_import",
  "owner": "skill-factory",
  "last_verified_at": "2026-03-20T07:57:00Z",
  "actions": {
    "default_action": {
      "description": "Default action migrated from v1",
      "module": "scripts.main",
      "function": "explore",
      "args": {
        "file_path": {
          "type": "string",
          "description": "Path to CSV file",
          "required": true
        },
        "action": {
          "type": "string",
          "description": "Exploration action",
          "required": true,
          "enum": [
            "preview",
            "summary",
            "filter",
            "sort",
            "group",
            "plot"
          ]
        },
        "query": {
          "type": "string",
          "description": "Filter query (pandas syntax)",
          "required": false
        },
        "columns": {
          "type": "array",
          "description": "Columns to select",
          "required": false
        },
        "limit": {
          "type": "integer",
          "description": "Number of rows to show",
          "required": false,
          "default": 10
        }
      }
    }
  },
  "routing": {
    "startup_expose": false,
    "startup_reason": "tabular_exploration_only",
    "hints": [
      "explicit_task_trigger_required"
    ]
  }
}
