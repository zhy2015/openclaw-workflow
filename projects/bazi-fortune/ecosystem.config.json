{
  "name": "bazi-fortune",
  "script": "./server.js",
  "cwd": "/root/.openclaw/workspace/projects/bazi-fortune",
  "instances": 1,
  "exec_mode": "fork",
  "env": {
    "NODE_ENV": "production",
    "PORT": 30000
  },
  "log_file": "./logs/combined.log",
  "out_file": "./logs/out.log",
  "error_file": "./logs/error.log",
  "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
  "merge_logs": true,
  "max_memory_restart": "500M",
  "restart_delay": 3000,
  "max_restarts": 10,
  "min_uptime": "10s",
  "autorestart": true,
  "watch": false
}
